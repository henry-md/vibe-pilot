{
  "name": "vibe-pilot",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "postinstall": "npm run prisma:generate",
    "dev:web": "PORT=${PORT:-3001} npm run dev --workspace @vibe-pilot/web",
    "build": "npm run build:web && npm run build:extension",
    "build:web": "npm run build --workspace @vibe-pilot/web",
    "start:web": "PORT=${PORT:-3001} npm run start --workspace @vibe-pilot/web",
    "lint": "npm run lint:web && npm run lint:extension",
    "lint:web": "npm run lint --workspace @vibe-pilot/web",
    "lint:extension": "npm run lint --workspace @vibe-pilot/extension",
    "build:extension": "npm run build --workspace @vibe-pilot/extension",
    "db:start": "docker compose --env-file apps/web/.env up -d postgres",
    "db:stop": "docker compose --env-file apps/web/.env down",
    "db:reset": "docker compose --env-file apps/web/.env down -v",
    "prisma:generate": "npm run prisma:generate --workspace @vibe-pilot/web",
    "prisma:migrate": "npm run prisma:migrate --workspace @vibe-pilot/web",
    "prisma:deploy": "npm run prisma:deploy --workspace @vibe-pilot/web",
    "prisma:studio": "npm run prisma:studio --workspace @vibe-pilot/web"
  }
}
